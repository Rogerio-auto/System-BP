# =============================================================================
# Manager Banco do Povo — variáveis de ambiente
# Copie para .env e preencha. NUNCA comitar .env real.
# =============================================================================

# ---- General ---------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# ---- PostgreSQL ------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=elemento
POSTGRES_USER=elemento
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgres://elemento:change-me-postgres-password@postgres:5432/elemento

# ---- API (apps/api) --------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=3333
API_PUBLIC_URL=http://localhost:3333

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-64-chars-long-please-rotate
JWT_REFRESH_SECRET=change-me-refresh-secret-min-64-chars-long-please-rotate
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS (CSV de origens permitidas — NUNCA usar *)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Token compartilhado backend ↔ langgraph-service
LANGGRAPH_INTERNAL_TOKEN=change-me-internal-token-rotate-regularly
LANGGRAPH_SERVICE_URL=http://langgraph-service:8000

# ---- Web (apps/web) --------------------------------------------------------
VITE_API_URL=http://localhost:3333
VITE_APP_NAME=Manager Banco do Povo

# ---- LangGraph Service -----------------------------------------------------
LANGGRAPH_HOST=0.0.0.0
LANGGRAPH_PORT=8000
BACKEND_INTERNAL_URL=http://api:3333

# ---- LLM Gateway (OpenRouter padrão) --------------------------------------
# OpenRouter é o gateway principal: 1 chave, qualquer modelo, billing unificado.
# https://openrouter.ai/keys
LLM_PROVIDER=openrouter                  # openrouter | anthropic | openai
OPENROUTER_API_KEY=sk-or-v1-change-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://elemento.local        # exigido pelo OpenRouter
OPENROUTER_APP_TITLE=Elemento Banco do Povo           # exigido pelo OpenRouter

# Modelo padrão por papel (cada nó pode sobrescrever via prompt_versions)
LLM_MODEL_CLASSIFIER=anthropic/claude-3.5-haiku
LLM_MODEL_REASONER=anthropic/claude-sonnet-4
LLM_MODEL_FALLBACK=openai/gpt-4o-mini

# Provedores diretos (opcionais — usados só se LLM_PROVIDER=anthropic|openai)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Custos
LLM_DAILY_BUDGET_USD=20
LLM_MAX_TOKENS_PER_CONVERSATION=8000

# ---- Chatwoot --------------------------------------------------------------
CHATWOOT_BASE_URL=https://chat.example.com
CHATWOOT_API_TOKEN=your-chatwoot-api-token
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_WEBHOOK_HMAC_SECRET=change-me-chatwoot-hmac-secret

# ---- WhatsApp Cloud API ---------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_VERIFY_TOKEN=change-me-verify-token
WHATSAPP_APP_SECRET=change-me-app-secret-for-hmac

# ---- LGPD baseline (F1-S24) ------------------------------------------------
# Chave AES-256-GCM para cifração de PII em coluna (doc 17 §8.1).
# Formato: base64 de exatamente 32 bytes (256 bits).
# Gerar: openssl rand -base64 32
# OBRIGATÓRIA em produção — falha de boot se ausente.
# Rotação: ver apps/api/docs/runbook-key-rotation.md
LGPD_DATA_KEY=__replace_with_openssl_rand_base64_32__

# Pepper HMAC-SHA256 para hash de dedupe de CPF/CNPJ (doc 17 §8.1).
# Formato: base64 de ≥32 bytes.
# Gerar: openssl rand -base64 32
# OBRIGATÓRIA em produção — falha de boot se ausente.
# ATENÇÃO: trocar este valor invalida todos os hashes de dedupe existentes.
LGPD_DEDUPE_PEPPER=__replace_with_openssl_rand_base64_32__
