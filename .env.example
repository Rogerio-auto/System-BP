# =============================================================================
# Manager Banco do Povo — variáveis de ambiente
# Copie para .env e preencha. NUNCA comitar .env real.
# =============================================================================

# ---- General ---------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# ---- PostgreSQL ------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=elemento
POSTGRES_USER=elemento
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgres://elemento:change-me-postgres-password@postgres:5432/elemento

# ---- API (apps/api) --------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=3333
API_PUBLIC_URL=http://localhost:3333

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-64-chars-long-please-rotate
JWT_REFRESH_SECRET=change-me-refresh-secret-min-64-chars-long-please-rotate
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS (CSV de origens permitidas — NUNCA usar *)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Token compartilhado backend ↔ langgraph-service
LANGGRAPH_INTERNAL_TOKEN=change-me-internal-token-rotate-regularly
LANGGRAPH_SERVICE_URL=http://langgraph-service:8000
# Timeout (ms) do worker livechat-ai ao chamar o LangGraph (F16-S49). O pré-atendimento
# agêntico leva ~8-12s; 8s causava fallback de handoff indevido. Deve ser > GRAPH_TIMEOUT_SEC (20s).
LANGGRAPH_AI_TIMEOUT_MS=25000

# ---- Web (apps/web) --------------------------------------------------------
VITE_API_URL=http://localhost:3333
VITE_APP_NAME=Manager Banco do Povo

# Meta Embedded Signup (opcional — habilita fluxo OAuth na tela de Canais).
# VITE_FACEBOOK_APP_ID: App ID do Meta App (público, injetado em build-time).
# VITE_FACEBOOK_CONFIG_ID: Config ID do Embedded Signup criado no painel Meta Developers
#   → Apps → seu App → WhatsApp → Embedded Signup → Configuration IDs.
# Sem essas duas variáveis o botão "Conectar com Meta" exibe aviso de config pendente.
VITE_FACEBOOK_APP_ID=
VITE_FACEBOOK_CONFIG_ID=

# ---- LangGraph Service -----------------------------------------------------
LANGGRAPH_HOST=0.0.0.0
LANGGRAPH_PORT=8000
# Timeout do grafo LangGraph em segundos (padrão: 8.0 — SLA doc 06 §4.4).
# Apenas para homologação/desenvolvimento local onde LLMs frios são mais lentos.
# NÃO alterar em produção — o default de 8.0s é normativo.
# GRAPH_TIMEOUT_SEC=30
BACKEND_INTERNAL_URL=http://api:3333

# ---- LLM Gateway (OpenRouter padrão) --------------------------------------
# OpenRouter é o gateway principal: 1 chave, qualquer modelo, billing unificado.
# https://openrouter.ai/keys
LLM_PROVIDER=openrouter                  # openrouter | anthropic | openai
OPENROUTER_API_KEY=sk-or-v1-change-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://elemento.local        # exigido pelo OpenRouter
OPENROUTER_APP_TITLE=Elemento Banco do Povo           # exigido pelo OpenRouter

# Modelo padrão por papel (cada nó pode sobrescrever via prompt_versions).
#
# CLASSIFIER — hot path; latência crítica; custo mínimo.
# REASONER   — Kimi K2 (moonshot/kimi-k2): throughput alto, custo competitivo,
#              raciocínio em PT-BR adequado. Requisito do CTO (F7-S01, 2026-05-22).
#              Pricing cadastrado em model_pricing (migration 0038).
# FALLBACK   — Claude Sonnet 4: plano B automático do gateway (F3-S00) quando
#              Kimi K2 retornar rate-limit (429) ou erro de serviço (5xx).
LLM_MODEL_CLASSIFIER=anthropic/claude-3.5-haiku
LLM_MODEL_REASONER=moonshot/kimi-k2
LLM_MODEL_FALLBACK=anthropic/claude-sonnet-4

# Provedores diretos (opcionais — usados só se LLM_PROVIDER=anthropic|openai)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Custos
LLM_DAILY_BUDGET_USD=20
LLM_MAX_TOKENS_PER_CONVERSATION=8000

# ---- Chatwoot --------------------------------------------------------------
CHATWOOT_BASE_URL=https://chat.example.com
CHATWOOT_API_TOKEN=your-chatwoot-api-token
CHATWOOT_ACCOUNT_ID=1
# Header: X-Chatwoot-Signature (hex, sem prefixo sha256=) — Chatwoot 3.x+
CHATWOOT_WEBHOOK_HMAC_SECRET=change-me-chatwoot-hmac-secret

# ---- WhatsApp Cloud API — webhook (obrigatórios) -------------------------
# Estas duas variáveis validam requisições do Meta para o endpoint de webhook.
# NÃO são credenciais de envio — não podem ser migradas para o banco.
# WHATSAPP_APP_SECRET: shared secret para validar HMAC SHA-256 (X-Hub-Signature-256).
#   Mínimo 16 chars; em produção usar entropia >= 32 chars.
# WHATSAPP_VERIFY_TOKEN: token de verificação para o handshake inicial GET do Meta.
#   Configurado em: Meta Developers → seu App → WhatsApp → Webhooks → Verify token.
WHATSAPP_VERIFY_TOKEN=change-me-verify-token
WHATSAPP_APP_SECRET=change-me-app-secret-for-hmac

# ---- LGPD baseline (F1-S24) ------------------------------------------------
# Chave AES-256-GCM para cifração de PII em coluna (doc 17 §8.1).
# Formato: base64 de exatamente 32 bytes (256 bits).
# Gerar: openssl rand -base64 32
# OBRIGATÓRIA em produção — falha de boot se ausente.
# Rotação: ver apps/api/docs/runbook-key-rotation.md
LGPD_DATA_KEY=__replace_with_openssl_rand_base64_32__

# Pepper HMAC-SHA256 para hash de dedupe de CPF/CNPJ e challenge token do 2FA (doc 17 §8.1).
# Formato: base64 de ≥32 bytes (string de ≥32 chars após codificação).
# Gerar: openssl rand -base64 32
# OBRIGATÓRIA em TODOS os ambientes — falha de boot se ausente (F8-S11 hardening).
# ATENÇÃO: trocar este valor invalida todos os hashes de dedupe existentes.
LGPD_DEDUPE_PEPPER=__replace_with_openssl_rand_base64_32__

# ---- Notion (F7-S04) --------------------------------------------------------
# Integration token de acesso read-only à Notion API (migração histórica de leads).
# Suboperador internacional temporário (LGPD §12.1) — ativo ≤30 dias.
# Criar em notion.so → Settings → Integrations → Internal → New Integration (read-only).
# Opcional: deixar em branco desabilita o adapter notion_leads.
NOTION_INTEGRATION_TOKEN=

# ---- Custeio LLM (F9-S00) --------------------------------------------------
# Taxa de câmbio BRL/USD para conversão de custos de modelo LLM em reais.
# NÃO é persistida no banco — lida em runtime pelo helper pricing.ts.
# OBRIGATÓRIA — boot falha se ausente ou <= 0.
# Atualizar manualmente ao trocar de faixa cambial (sugestão: revisão mensal).
# Fonte de referência: https://www.bcb.gov.br/estabilidadefinanceira/cotacoesdolar
FX_BRL_PER_USD=5.75

# ---- Workers periódicos (F5-S02) -------------------------------------------
# Intervalo do tick do worker followup-scheduler em milissegundos.
# Default: 60000 (1 minuto). Produção: 300000 (5 minutos) é suficiente.
# Mínimo: 1000ms (proteção contra sobrecarga no banco).
# Opcional — se ausente usa o default de 60000ms.
FOLLOWUP_SCHEDULER_TICK_MS=60000

# ---- DEPRECATED após F20 — remover do .env --------------------------------
# As variáveis abaixo eram credenciais de envio WhatsApp carregadas em boot.
# A partir de F20 (S03/S04/S05/S06) as credenciais ficam na tabela `channels`
# (channel_credentials JSONB cifrado) e são carregadas em runtime por canal.
# Se presentes no .env, a API emite um warning de boot com instruções de migração.
# MIGRAÇÃO: remova as linhas abaixo e configure as credenciais via /api/channels/:id.
#
# @deprecated F20 — substituídas por channel_credentials na tabela channels
# META_WHATSAPP_ACCESS_TOKEN=your-meta-system-user-token
# META_WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# META_WABA_ID=your-waba-id
# META_APP_ID=your-meta-app-id

# ---- Meta App (backend) — Embedded Signup + validação HMAC ----------------
# FACEBOOK_APP_ID: App ID do Meta App (backend — troca de code → token).
# FACEBOOK_APP_SECRET: App Secret para HMAC de webhook e troca de token.
# Necessários para o endpoint POST /api/channels/meta/whatsapp/discover.
# Se ausentes, o endpoint retorna 503 FEATURE_NOT_CONFIGURED.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Intervalo do tick do worker followup-sender em milissegundos.
# Default: 30000 (30 segundos). Processa até 50 jobs por tick.
# Mínimo: 1000ms.
FOLLOWUP_SENDER_TICK_MS=30000

# ---- OpenAPI spec (F10-S09) -------------------------------------------
# Expoe GET /openapi.json quando true. Em producao, deixar false para evitar
# fingerprinting. Em dev/staging, automaticamente exposto (NODE_ENV != production).
OPENAPI_PUBLIC_ENABLED=false

# Desliga rate-limit estrito de login (5 req/15min/IP) em dev/demo.
# Ignorado em producao por seguranca. Mantenha false fora de dev.
AUTH_RATE_LIMIT_DISABLED=false

# ---- Redis (F16-S01 live chat) -----------------------------------------------
# URL de conexao Redis (formato: redis://:password@host:6379).
# Em dev local, usar: redis://localhost:6379
# Em Docker Compose: redis://redis:6379
# Opcional se live chat nao estiver ativo.
REDIS_URL=redis://redis:6379

# ---- RabbitMQ (F16-S01 live chat) --------------------------------------------
# Senha do user 'elemento' no RabbitMQ (lida pelo docker-compose via RABBITMQ_DEFAULT_PASS).
# Deve corresponder ao host:pass na RABBITMQ_URL abaixo.
# Em dev local sem Docker, nao e necessaria (usa guest:guest direto na URL).
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq-password

# URL de conexao AMQP (formato: amqp://user:pass@host:5672).
# Em dev local, usar: amqp://guest:guest@localhost:5672
# Em Docker Compose: amqp://elemento:@rabbitmq:5672
# Opcional se live chat nao estiver ativo.
RABBITMQ_URL=amqp://elemento:change-me-rabbitmq-password@rabbitmq:5672

# ---- Storage de mídia do live chat -------------------------------------------
# Seleciona o driver de storage: 'r2' (Cloudflare R2, default) ou 'supabase'.
# Use 'supabase' quando R2 não estiver configurado (ex: VPS com Supabase local — LGPD).
# Quando STORAGE_PROVIDER=supabase, as variáveis SUPABASE_STORAGE_* abaixo são obrigatórias.
STORAGE_PROVIDER=r2

# ---- Cloudflare R2 (STORAGE_PROVIDER=r2) -------------------------------------
# Storage de midia do live chat. Criar bucket no Cloudflare R2.
# R2_ACCOUNT_ID: visivel em Cloudflare Dashboard > Account ID.
# R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY: gerar em R2 > Manage API Tokens.
# R2_BUCKET: nome do bucket criado.
# R2_PUBLIC_URL: URL base publica (ex: https://media.elemento.app).
#   Requer Custom Domain configurado no R2 ou R2.dev habilitado.
# Todas opcionais se live chat nao estiver ativo em dev.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=elemento-media
R2_PUBLIC_URL=https://media.elemento.app

# ---- Supabase Storage (STORAGE_PROVIDER=supabase) ----------------------------
# Alternativa LGPD ao R2: mídia armazenada no Supabase Storage do VPS (in-country).
# SUPABASE_STORAGE_URL: URL interna do Supabase Storage (para operações server-side).
#   Em Docker Compose: http://supabase-kong:8000 (ou o serviço kong/storage interno).
#   Em Supabase cloud: https://<project-ref>.supabase.co
# SUPABASE_STORAGE_PUBLIC_URL: URL base pública para links de download e signed upload PUT.
#   Ex: https://storage.bancodopovoderondonia.org.br (nginx/proxy externo).
#   Pode ser igual a SUPABASE_STORAGE_URL em dev local.
# SUPABASE_SERVICE_KEY: service_role JWT do Supabase.
#   Disponível em: Supabase Dashboard → Settings → API → service_role key.
#   ATENÇÃO LGPD: credencial sensível — NUNCA expor no frontend ou logar.
# SUPABASE_STORAGE_BUCKET: nome do bucket de mídia (deve ser criado previamente).
#   Ex: elemento-media (pode ser público para links diretos de download).
# Todas opcionais se STORAGE_PROVIDER=r2 (default).
# SUPABASE_STORAGE_URL=http://localhost:8000
# SUPABASE_STORAGE_PUBLIC_URL=http://localhost:8000
# SUPABASE_SERVICE_KEY=your-supabase-service-role-jwt-secret
# SUPABASE_STORAGE_BUCKET=elemento-media

# ---- Email via Resend (F24-S03) ------------------------------------------
# Liga/desliga o envio de emails de notificação transacional.
# Default false: no-op seguro — sem envio mesmo com chave configurada.
# Habilitar apenas após verificar o domínio remetente no Resend.
# Quando true, RESEND_API_KEY e EMAIL_FROM são obrigatórios (boot falha se ausentes).
NOTIFICATIONS_EMAIL_ENABLED=false

# Chave de API do Resend (https://resend.com/api-keys).
# LGPD: credencial sensível — nunca logar, nunca expor no frontend.
# Necessária quando NOTIFICATIONS_EMAIL_ENABLED=true.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endereço remetente verificado no Resend (Resend → Domains).
# Formato: "Nome Exibido <email@dominio-verificado.com.br>"
# Necessário quando NOTIFICATIONS_EMAIL_ENABLED=true.
# EMAIL_FROM=Banco do Povo <noreply@bancodopovoderondonia.org.br>

# Endereço de Reply-To opcional.
# Quando ausente, o campo Reply-To não é incluído no email.
# EMAIL_REPLY_TO=suporte@bancodopovoderondonia.org.br

# ---- Web Push / VAPID (F27-S06) ------------------------------------------
# Liga/desliga o quarto sender do motor de notificações (Web Push).
# Default false: no-op seguro. A camada operacional é a feature flag
# `pwa.enabled` — as duas precisam estar ligadas para o push funcionar.
# Quando true, VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY e VAPID_SUBJECT são
# obrigatórios (boot falha se ausentes).
NOTIFICATIONS_PUSH_ENABLED=false

# Par de chaves VAPID (RFC 8292) — gerar uma única vez com:
#   npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY NÃO é segredo (é exposta ao frontend via
# GET /api/notifications/push/public-key), mas mantenha valores reais fora
# do versionamento — preencha apenas no .env local/secret manager.
# Necessária quando NOTIFICATIONS_PUSH_ENABLED=true.
# VAPID_PUBLIC_KEY=BExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chave privada VAPID — SEGREDO. NUNCA commitar, nunca expor no frontend,
# nunca logar. Necessária quando NOTIFICATIONS_PUSH_ENABLED=true.
# VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Contato do mantenedor exigido pelo protocolo VAPID (RFC 8292).
# Formato: "mailto:contato@dominio.com" ou "https://dominio.com".
# Necessário quando NOTIFICATIONS_PUSH_ENABLED=true.
# VAPID_SUBJECT=mailto:suporte@bancodopovoderondonia.org.br
