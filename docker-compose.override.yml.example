# =============================================================================
# docker-compose.override.yml.example — Overrides para desenvolvimento local
#
# COMO USAR:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   # Edite conforme sua maquina (caminhos de volume, portas, etc.)
#   docker compose up -d
#
# ATENCAO:
#   - Este arquivo e um EXEMPLO. Nunca comite docker-compose.override.yml.
#   - O arquivo override e carregado automaticamente pelo Docker Compose
#     quando presente no mesmo diretorio que docker-compose.yml.
#   - Em producao, apenas docker-compose.yml e usado (sem override).
# =============================================================================
name: elemento

services:
  postgres:
    depends_on: {}

  api:
    build:
      context: .
      dockerfile: apps/api/Dockerfile
    command: ['pnpm', '--filter', '@elemento/api', 'dev']
    volumes:
      - ./apps/api/src:/repo/apps/api/src:ro
      - ./packages:/repo/packages:ro
    environment:
      NODE_ENV: development
    depends_on:
      postgres:
        condition: service_healthy

  langgraph-service:
    command:
      [
        'uvicorn',
        'app.main:app',
        '--host',
        '0.0.0.0',
        '--port',
        '8000',
        '--reload',
      ]
    volumes:
      - ./apps/langgraph-service/app:/app/app:ro
    depends_on:
      api:
        condition: service_healthy

  web:
    build:
      context: .
      dockerfile: apps/web/Dockerfile
    command: ['pnpm', '--filter', '@elemento/web', 'dev', '--host']
    volumes:
      - ./apps/web/src:/repo/apps/web/src:ro
      - ./apps/web/public:/repo/apps/web/public:ro
      - ./apps/web/index.html:/repo/apps/web/index.html:ro
    ports:
      - '5173:5173'
    environment:
      VITE_API_URL: http://localhost:3333
    depends_on:
      api:
        condition: service_healthy
    healthcheck:
      test: ['CMD-SHELL', 'wget --quiet --tries=1 --spider http://localhost:5173/ || exit 1']
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
