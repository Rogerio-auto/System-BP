# =============================================================================
# Dockerfile.dev — apps/web (DEV ONLY)
# Vite dev server com hot reload. Context = repo root.
# =============================================================================
FROM node:20-alpine
RUN corepack enable && corepack prepare pnpm@9.12.0 --activate
RUN addgroup -S app && adduser -S app -G app
WORKDIR /app
COPY --chown=app:app . .
RUN pnpm install
USER app
EXPOSE 5173
CMD ["pnpm", "--filter", "@elemento/web", "dev", "--host", "0.0.0.0"]
