# =============================================================================
# Dockerfile.dev — apps/api (DEV ONLY)
# Inclui devDependencies + tsx watch. NÃO usar em produção.
# =============================================================================
FROM node:20-alpine
RUN corepack enable && corepack prepare pnpm@9.12.0 --activate
RUN addgroup -S app && adduser -S app -G app
WORKDIR /app
COPY --chown=app:app package.json pnpm-lock.yaml* ./
RUN pnpm install
COPY --chown=app:app . .
USER app
EXPOSE 3333
CMD ["pnpm", "dev"]
