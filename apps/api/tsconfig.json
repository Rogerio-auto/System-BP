{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@elemento/tsconfig/node.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": true,
    "declarationMap": false
  },
  "include": ["src"]
}
