{
  "name": "@elemento/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx --env-file=../../.env watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file=../../.env src/db/migrate.ts",
    "db:seed": "tsx --env-file=../../.env scripts/seed.ts",
    "db:studio": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@elemento/shared-schemas": "workspace:*",
    "@elemento/shared-types": "workspace:*",
    "@fastify/cors": "10.0.1",
    "@fastify/helmet": "12.0.1",
    "@fastify/rate-limit": "10.1.1",
    "@fastify/sensible": "6.0.1",
    "bcryptjs": "2.4.3",
    "drizzle-orm": "0.34.1",
    "fastify": "^5.3.2",
    "fastify-type-provider-zod": "4.0.1",
    "jose": "5.9.3",
    "libphonenumber-js": "^1.13.1",
    "pg": "8.13.0",
    "pino": "9.4.0",
    "pino-pretty": "11.2.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@elemento/eslint-config": "workspace:*",
    "@elemento/tsconfig": "workspace:*",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.16.10",
    "@types/pg": "8.11.10",
    "drizzle-kit": "0.25.0",
    "eslint": "9.11.1",
    "tsx": "4.19.1",
    "typescript": "5.6.2",
    "vitest": "^2.1.9"
  }
}
